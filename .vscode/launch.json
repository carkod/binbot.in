{
  "version": "0.0.2",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "React: Binbot.in",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src",
      "env": {
        "NODE_ENV": "development",
        "PORT": "3000",
        "VITE_PUBLIC_URL": "http://localhost:3000"
      },
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ]
}
